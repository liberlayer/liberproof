# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string

# Database
DB_PATH=./data/liberproof.db

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://app.liberproof.com,https://verify.liberproof.com

# Chain anchoring (optional — leave blank to skip anchoring)
EVM_RPC_URL=
EVM_PRIVATE_KEY=
LIBERLAND_WS_URL=wss://mainnet.liberland.org
LIBERLAND_SEED=
